{
  "title": "Go Microservices - 4 Golden Signals",
  "uid": "go-microservices-golden-v2",
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "\ud83d\udea6 Traffic \u2014 Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "rate(auth_service_requests_total[1m])",
          "legendFormat": "auth \u2014 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "rate(product_service_requests_total[1m])",
          "legendFormat": "product \u2014 {{endpoint}}",
          "refId": "B"
        },
        {
          "expr": "rate(user_service_requests_total[1m])",
          "legendFormat": "user \u2014 {{endpoint}}",
          "refId": "C"
        },
        {
          "expr": "rate(order_service_requests_total[1m])",
          "legendFormat": "order \u2014 {{endpoint}}",
          "refId": "D"
        },
        {
          "expr": "rate(email_service_emails_total[1m])",
          "legendFormat": "email \u2014 {{type}}",
          "refId": "E"
        }
      ]
    },
    {
      "id": 2,
      "title": "\u23f1\ufe0f Latency \u2014 p99 Response Time",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1.0
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(auth_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "auth p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(auth_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "auth p50",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(product_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "product p99",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.50, rate(product_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "product p50",
          "refId": "D"
        },
        {
          "expr": "histogram_quantile(0.99, rate(user_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "user p99",
          "refId": "E"
        },
        {
          "expr": "histogram_quantile(0.50, rate(user_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "user p50",
          "refId": "F"
        },
        {
          "expr": "histogram_quantile(0.99, rate(order_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "order p99",
          "refId": "G"
        },
        {
          "expr": "histogram_quantile(0.50, rate(order_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "order p50",
          "refId": "H"
        }
      ]
    },
    {
      "id": 3,
      "title": "\ud83d\udcca Total Requests (cumulative)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(auth_service_requests_total)",
          "legendFormat": "auth total",
          "refId": "A"
        },
        {
          "expr": "sum(product_service_requests_total)",
          "legendFormat": "product total",
          "refId": "B"
        },
        {
          "expr": "sum(user_service_requests_total)",
          "legendFormat": "user total",
          "refId": "C"
        },
        {
          "expr": "sum(order_service_requests_total)",
          "legendFormat": "order total",
          "refId": "D"
        },
        {
          "expr": "sum(email_service_emails_total)",
          "legendFormat": "email total",
          "refId": "E"
        }
      ]
    },
    {
      "id": 4,
      "title": "\ud83d\udcc8 Average Latency",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "rate(auth_service_request_duration_seconds_sum[5m]) / rate(auth_service_request_duration_seconds_count[5m])",
          "legendFormat": "auth avg",
          "refId": "A"
        },
        {
          "expr": "rate(product_service_request_duration_seconds_sum[5m]) / rate(product_service_request_duration_seconds_count[5m])",
          "legendFormat": "product avg",
          "refId": "B"
        },
        {
          "expr": "rate(user_service_request_duration_seconds_sum[5m]) / rate(user_service_request_duration_seconds_count[5m])",
          "legendFormat": "user avg",
          "refId": "C"
        },
        {
          "expr": "rate(order_service_request_duration_seconds_sum[5m]) / rate(order_service_request_duration_seconds_count[5m])",
          "legendFormat": "order avg",
          "refId": "D"
        }
      ]
    },
    {
      "id": 5,
      "title": "\ud83d\udd27 Saturation \u2014 Goroutines",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "go_goroutines{job=\"auth-service\"}",
          "legendFormat": "auth goroutines",
          "refId": "A"
        },
        {
          "expr": "go_goroutines{job=\"product-service\"}",
          "legendFormat": "product goroutines",
          "refId": "B"
        },
        {
          "expr": "go_goroutines{job=\"user-service\"}",
          "legendFormat": "user goroutines",
          "refId": "C"
        },
        {
          "expr": "go_goroutines{job=\"order-service\"}",
          "legendFormat": "order goroutines",
          "refId": "D"
        },
        {
          "expr": "go_goroutines{job=\"email-service\"}",
          "legendFormat": "email goroutines",
          "refId": "E"
        }
      ]
    },
    {
      "id": 6,
      "title": "\ud83d\udce6 Order Service",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 7,
      "title": "Order \u2014 Request Rate by Endpoint (req/s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(order_service_requests_total[1m])",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Order \u2014 Latency p99 / p50 by Endpoint",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, rate(order_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, rate(order_service_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Orders Created (total)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(order_service_requests_total{endpoint=\"/api/v1/orders\"})",
          "legendFormat": "POST /api/v1/orders",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Order \u2014 Avg Latency by Endpoint",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 21,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(order_service_request_duration_seconds_sum[5m]) / rate(order_service_request_duration_seconds_count[5m])",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    }
  ]
}